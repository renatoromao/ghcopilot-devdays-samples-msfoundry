# Microsoft Foundry (Azure AI Projects) configuration.
# Authenticate locally with `az login` so DefaultAzureCredential picks it up.

# Required: Foundry/AI Project endpoint, e.g.
# https://<your-foundry>.services.ai.azure.com/api/projects/<your-project>
AZURE_AI_PROJECT_ENDPOINT=https://msfoundry-ghcopilot-sjc.services.ai.azure.com/api/projects/DevDay

# Option A: use an existing Foundry agent
FOUNDRY_AGENT_ID=

# Option B: create one on the fly using a model deployment
FOUNDRY_MODEL_DEPLOYMENT=gpt-5.4-mini-1
AGENT_NAME=foundry-chat-agent
AGENT_DESCRIPTION=Foundry chat application agent
AGENT_INSTRUCTIONS=You are a helpful assistant for the Foundry chat application.

# Optional overrides
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=